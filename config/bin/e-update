#!/usr/bin/env sh
set -eu

REPO_SLUG="${E_TERMINAL_REPO:-tweathers-sec/e-terminal}"
REPO_URL="${E_TERMINAL_REPO_URL:-https://github.com/${REPO_SLUG}.git}"
VERSION_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/e-terminal/commit"

FORCE=0
for a in "$@"; do
  case "$a" in
    -f|--force) FORCE=1 ;;
    -V|--version) [ -f "$VERSION_FILE" ] && cat "$VERSION_FILE" || echo "unknown"; exit 0 ;;
    -h|--help) echo "usage: e-update [--force] [--version]"; exit 0 ;;
  esac
done

command -v git >/dev/null 2>&1 || { echo "e-update: git is required" >&2; exit 1; }

remote="$(git ls-remote "$REPO_URL" HEAD 2>/dev/null | awk 'NR==1{print $1}')"
installed=""; [ -f "$VERSION_FILE" ] && installed="$(cat "$VERSION_FILE" 2>/dev/null || true)"
if [ "$FORCE" -ne 1 ] && [ -n "$remote" ] && [ "$remote" = "$installed" ]; then
  echo "e-update: already up to date ($(printf '%.7s' "$installed"))"
  exit 0
fi
[ -n "$installed" ] && [ -n "$remote" ] && echo "e-update: $(printf '%.7s' "$installed") -> $(printf '%.7s' "$remote")"

tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
echo "e-update: fetching latest ($REPO_URL)"
git clone --depth 1 "$REPO_URL" "$tmp/src" || { echo "e-update: fetch failed" >&2; exit 1; }
[ -f "$tmp/src/install.sh" ] || { echo "e-update: bad checkout (no install.sh)" >&2; exit 1; }

echo "e-update: installing"
SKIP_ROOT=1 SKIP_SHELL_CHANGE=1 SKIP_BREW=1 SKIP_APT=1 HOMEBREW_NO_AUTO_UPDATE=1 bash "$tmp/src/install.sh"
echo "e-update: done — open a new terminal to load changes"
