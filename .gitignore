# Local overrides & secrets - never commit
*.local
*.local.nu
.zshrc.local
config/nushell/env.local.nu

# Backups / rollback snapshots
.e-terminal-backup/
e-terminal-rollback/

# Installed-commit marker (written by the installer, read by e-update)
.e-terminal-commit

# Private notes (client mappings, scratch) - never commit
notes/

# Editor/agent local state
.claude/

# OS cruft
.DS_Store
Thumbs.db

# Downloaded font artifacts
fonts/*.tar.xz
fonts/*.zip
fonts/*.ttf
fonts/*.otf
